# ==============================================================
# Sentinel — Environment variables
# Copy to .env and fill in values. Never commit .env to git.
# ==============================================================

# ── Database (PostgreSQL) ──────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Observability ──────────────────────────────────────────────
# Leave empty in development — Sentry is disabled when blank
SENTRY_DSN=
ENVIRONMENT=development   # development | staging | production

# ── CORS ───────────────────────────────────────────────────────
# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# ── Drift detection tuning ─────────────────────────────────────
EWMA_LAMBDA=0.2
EWMA_SIGMA_MULTIPLIER=3.0
DRIFT_BATCH_SIZE=500
DRIFT_INTERVAL_SECONDS=60
ALERT_COOLDOWN_SECONDS=600
